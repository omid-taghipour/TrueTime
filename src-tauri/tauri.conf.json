{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrueTime",
  "version": "1.1.0",
  "identifier": "app.truetime.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TrueTime",
        "width": 420,
        "height": 680,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxMjdGRkYyRUNCODg3ClJXU0h1T3p5L3lmQkFDL1hqSXFqZ21CSXJnVXd0SUxrTm5pVXlZWm5XQkFLQVNyRy9nWjZRaGdECg==",
      "endpoints": [
        "https://github.com/omid-taghipour/TrueTime/releases/latest/download/latest.json"
      ]
    }
  }
}
