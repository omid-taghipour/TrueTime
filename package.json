{
  "name": "truetime",
  "description": "TrueTime is a clean, cross-platform desktop stopwatch app built with Tauri, React, and TypeScript. Run multiple stopwatches with mutual exclusion, millisecond precision, and crash-safe state.",
  "license": "MIT",
  "author": "Omid Taghipour",
  "repository": {
    "type": "git",
    "url": "https://github.com/omid-taghipour/TrueTime.git"
  },
  "keywords": [
    "tauri",
    "react",
    "typescript",
    "stopwatch",
    "desktop-app",
    "cross-platform"
  ],
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "bump-version": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
